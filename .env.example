# ---------------------------------------------------------------------------
# GateCall — environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# --- Supabase (server-side only; never exposed to the browser) -------------
# Project Settings -> Data API -> Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Project Settings -> API Keys -> service_role key (secret)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Supabase (browser — powers live updates via Supabase Realtime) --------
# NEXT_PUBLIC_SUPABASE_URL is the same value as SUPABASE_URL above.
# Anon key: Project Settings -> API Keys -> anon / public key (safe in browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Bolna Voice AI --------------------------------------------------------
# Bolna dashboard -> Developers / API Keys
BOLNA_API_KEY=YOUR-BOLNA-API-KEY
# The agent id you created from docs/bolna-agent-setup.md
BOLNA_AGENT_ID=YOUR-BOLNA-AGENT-ID
# Optional — only if you call from a dedicated/purchased number.
# Leave unset to use Bolna's default phone number.
# BOLNA_FROM_NUMBER=+91XXXXXXXXXX

# --- Demo phone numbers ----------------------------------------------------
# The three "missing" passengers are dialled on these numbers (E.164 format).
# Put a phone you can answer here to role-play a passenger during the demo.
DEMO_PHONE_1=+91XXXXXXXXXX
DEMO_PHONE_2=+91XXXXXXXXXX
DEMO_PHONE_3=+91XXXXXXXXXX

# --- Gate console login ----------------------------------------------------
# Credentials the gate agent signs in with. Pick any values you like.
# If both are left blank the app runs with no login (local development only) —
# always set them before deploying so the public URL is protected.
GATE_USER=gate-agent
GATE_PASSWORD=change-this-password
